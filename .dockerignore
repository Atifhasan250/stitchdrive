# Exclude everything by default
**

# Re-include only the specific subdirectories we need for builds
!backend/
!frontend/
!package.json
!package-lock.json

# Exclude unnecessary files within subdirectories
backend/node_modules/
backend/dist/
backend/build/
backend/.env
backend/config/credentials.json

frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/.env
frontend/.env.local

# Exclude OS & IDE junk
.git/
.gitignore
.dockerignore
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
